  m_Name: TargetTap
  m_EditorClassIdentifier: 
  gameName: TargetTap
  gameDescription: "Target Tap challenges players to quickly hit floor targets as
    they appear. Stay sharp and tap fast\u2014accuracy and speed are the key to winning!"
  gameImage: {fileID: 21300000, guid: 16d96d20e68a540ec94526a1a54481ac, type: 3}
  gameTags:
  - Coordination
  - Balance
  gameIcon:
  - {fileID: 21300000, guid: 514b89ffa304c4d468a7ef2856e9f62c, type: 3}
  - {fileID: 21300000, guid: 0239f1d9edc7e4d7db0862b148943429, type: 3}
  Settings:
  - cardName: Target Height
    cardDescription: The Height of the target from the ground
    cardImage: {fileID: 21300000, guid: d1f6d64acb1864bd6a02b62f93e9d19b, type: 3}
    SettingValue:
      value: 0
      min: 0
      max: 0.5
      units: 
      LiveSetting: 1
    sliderisWholeNumber: 0
  - cardName: Target Hold Time
    cardDescription: The length of time in second you need to hold hitting a target
    cardImage: {fileID: 21300000, guid: 7030bc38134e043b884f2ff9ee0d7d14, type: 3}
    SettingValue:
      value: 1.5
      min: 0
      max: 5
      units: 
      LiveSetting: 1
    sliderisWholeNumber: 0
  - cardName: Target Size
    cardDescription: The size of the target to hit
    cardImage: {fileID: 21300000, guid: a3c2c95342be348f2bfd395c72c3245e, type: 3}
    SettingValue:
      value: 1
      min: 1
      max: 2
      units: 
      LiveSetting: 1
    sliderisWholeNumber: 0
  - cardName: Number of Targets
    cardDescription: Total Number of Targets you need to hit.
    cardImage: {fileID: 21300000, guid: 16d96d20e68a540ec94526a1a54481ac, type: 3}
    SettingValue:
      value: 10
      min: 10
      max: 100
      units: 
      LiveSetting: 0
    sliderisWholeNumber: 1
  - cardName: Home Box Hold Time
    cardDescription: The size of the center home box
    cardImage: {fileID: 21300000, guid: 216d4c113ede24337a18f78ab558af8a, type: 3}
    SettingValue:
      value: 2
      min: 0
      max: 5
      units: Seconds
      LiveSetting: 1
    sliderisWholeNumber: 0
  - cardName: Home Box Size
    cardDescription: The size of the center home box
    cardImage: {fileID: 21300000, guid: 216d4c113ede24337a18f78ab558af8a, type: 3}
    SettingValue:
      value: 0.5
      min: 0.5
      max: 1
      units: 
      LiveSetting: 1
    sliderisWholeNumber: 0
  RestartGame: 1
  CardOrder: 1
  SpecialCardPlatform:
    cardName: Platform Size
